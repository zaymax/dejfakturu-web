generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum CustomerType {
  COMPANY
  PERSON
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  VOID
}

enum InvoiceType {
  STANDARD_NO_VAT
  STANDARD_WITH_VAT
  PROFORMA
  ADVANCE
}

enum VatMode {
  NON_VAT_PAYER
  VAT_PAYER
  REVERSE_CHARGE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  COD
}

enum InvoiceLanguage {
  CS
  EN
  DE
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships OrganizationMember[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  ico                 String?
  dic                 String?
  vatPayer            Boolean  @default(false)
  street              String?
  city                String?
  postalCode          String?
  country             String   @default("CZ")
  email               String?
  phone               String?
  website             String?
  bankAccount         String?
  iban                String?
  defaultCurrency     String   @default("CZK")
  defaultDueDays      Int      @default(14)
  invoiceNumberPrefix String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customers Customer[]
  invoices  Invoice[]
  members   OrganizationMember[]
  sequences InvoiceNumberSequence[]
}

model OrganizationMember {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  type           CustomerType @default(COMPANY)
  name           String
  ico            String?
  dic            String?
  email          String?
  phone          String?
  street         String?
  city           String?
  postalCode     String?
  country        String       @default("CZ")
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@unique([organizationId, ico])
  @@index([organizationId, name])
}

model InvoiceNumberSequence {
  id             String   @id @default(uuid())
  organizationId String
  year           Int
  prefix         String   @default("")
  nextNumber     Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, year, prefix])
}

model Invoice {
  id                String          @id @default(uuid())
  organizationId    String
  customerId        String?
  number            String
  variableSymbol    String?
  invoiceType       InvoiceType     @default(STANDARD_NO_VAT)
  vatMode           VatMode         @default(NON_VAT_PAYER)
  status            InvoiceStatus   @default(DRAFT)
  language          InvoiceLanguage @default(CS)
  currency          String          @default("CZK")
  paymentMethod     PaymentMethod   @default(BANK_TRANSFER)
  issueDate         DateTime
  dueDate           DateTime
  taxableSupplyDate DateTime?
  subtotalCents     Int             @default(0)
  discountCents     Int             @default(0)
  totalVatCents     Int             @default(0)
  totalCents        Int             @default(0)
  customerSnapshot  Json?
  supplierSnapshot  Json?
  notes             String?
  pdfStorageKey     String?
  sentAt            DateTime?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([customerId])
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String
  position       Int
  description    String
  quantity       Decimal  @db.Decimal(12, 3)
  unit           String   @default("ks")
  unitPriceCents Int
  vatRate        Decimal  @default(0) @db.Decimal(5, 2)
  totalCents     Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, position])
}
